      "parameters": {
        "language": "pythonNative",
        "pythonCode": "import json\n\n# ── inputs ────────────────────────────────────────────────────────────────────\npipeline_items = [item['json'] for item in _items if 'output' in item['json']]\nsheet_rows     = [item['json'] for item in _items if 'row_number' in item['json']]\n\nresults = []\n\nfor idx, (agent_output_wrapper, sheet_row) in enumerate(zip(pipeline_items, sheet_rows)):\n    agent_output = agent_output_wrapper.get('output', {})\n\n    # ── extract actual values ─────────────────────────────────────────────────\n    actual_lead_id            = agent_output.get('lead_id', '')\n    actual_priority_tier      = agent_output.get('priority_tier', '')\n    actual_channel_executed   = agent_output.get('channel_executed', '')\n    actual_execution_status   = agent_output.get('execution_status', '')\n    actual_fallback_triggered = agent_output.get('fallback_triggered', False)\n    actual_risk_flags         = agent_output.get('risk_flags', [])\n    message_snapshot          = agent_output.get('message_snapshot', {})\n\n    actual_message = (\n        message_snapshot.get('sms') or\n        (message_snapshot.get('email') or {}).get('body') or\n        (message_snapshot.get('call') or {}).get('opening_line') or\n        ''\n    )\n\n    # ── extract expected values ───────────────────────────────────────────────\n    input_lead_id             = sheet_row.get('lead_id', '')\n    expected_priority_tier    = sheet_row.get('expected_priority_tier', '')\n    expected_channel_executed = sheet_row.get('expected_channel_executed', '')\n    expected_execution_status = sheet_row.get('expected_execution_status', '')\n    expected_fallback         = sheet_row.get('expected_fallback_triggered', False)\n    if isinstance(expected_fallback, str):\n        expected_fallback = expected_fallback.strip().upper() == 'TRUE'\n\n    # ── code eval checks ──────────────────────────────────────────────────────\n    lead_id_consistent       = actual_lead_id == input_lead_id\n    channel_correct          = actual_channel_executed == expected_channel_executed\n    tier_correct             = actual_priority_tier == expected_priority_tier\n    execution_status_correct = actual_execution_status == expected_execution_status\n    fallback_correct         = actual_fallback_triggered == expected_fallback\n    contact_channel_match    = actual_execution_status != 'contact_missing'\n    pipeline_completed       = bool(actual_lead_id) and 'error' not in agent_output\n\n    if actual_priority_tier == 'hot' and actual_channel_executed == 'no_action':\n        no_action_on_hot_flag = any('no_action on hot' in f.lower() for f in actual_risk_flags)\n    else:\n        no_action_on_hot_flag = True\n\n    results.append({\n        'json': {\n            'lead_id':                   input_lead_id,\n            'Scenario':                  sheet_row.get('Scenario', ''),\n            'textContent':               sheet_row.get('textContent', ''),\n            'expected_objective':        sheet_row.get('expected_objective', ''),\n            'actual_message':            actual_message,\n            'actual_priority_tier':      actual_priority_tier,\n            'actual_channel_executed':   actual_channel_executed,\n            'actual_execution_status':   actual_execution_status,\n            'actual_fallback_triggered': actual_fallback_triggered,\n            'lead_id_consistent':        lead_id_consistent,\n            'channel_correct':           channel_correct,\n            'tier_correct':              tier_correct,\n            'execution_status_correct':  execution_status_correct,\n            'fallback_correct':          fallback_correct,\n            'contact_channel_match':     contact_channel_match,\n            'no_action_on_hot_flag':     no_action_on_hot_flag,\n            'pipeline_completed':        pipeline_completed,\n        },\n        'pairedItem': [\n            {'item': idx},\n            {'item': idx + len(pipeline_items)}\n        ]\n    })\n\nreturn results\n"
      },
